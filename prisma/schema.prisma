generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum PeladaStatus {
  WAITING   // Aguardando jogadores
  FULL      // Vagas esgotadas
  FINISHED  // Finalizada
  CANCELLED // Cancelada pelo organizador
}

enum ReviewTag {
  CRAQUE_DA_PELADA  // Melhor da resenha
  JOGA_FACIL        // Habilidoso, fácil de jogar junto
  PASSA_DE_ANO      // Abaixo do esperado
  PONTUAL           // Sempre no horário
  FAIR_PLAY         // Jogo limpo, sem confusão
  BOA_COMUNICACAO   // Se comunica bem em campo
}

enum UserRole {
  PLAYER
  OWNER
  ADMIN
}

// Conquistas exibidas no perfil — atribuídas pelo sistema automaticamente
enum UserBadge {
  CONFIAVEL        // Presença >= 90%
  CRAQUE           // Nota média >= 4.5
  ORGANIZADOR_NATO // 5 ou mais peladas criadas
}

enum PlaceStatus {
  OPEN
  CLOSED
}

enum CourtType {
  SOCIETY      // Campo society (grama sintética, menor)
  CAMPO        // Campo de futebol convencional
  FUTSAL       // Quadra de futsal (coberta)
  AREIA        // Quadra de areia (futevôlei)
  VOLEI        // Quadra de vôlei indoor
  VOLEI_AREIA  // Quadra de vôlei de areia
  HANDBALL     // Quadra de handball
  PETECA       // Quadra de peteca
  BEACH_TENNIS // Quadra de beach tennis
  BASQUETE     // Quadra de basquete
  TENIS        // Quadra de tênis
}

enum CourtStatus {
  OPEN
  CLOSED
}

enum NotificationType {
  PLAYER_JOINED
  PLAYER_LEFT
  PELADA_FULL
  PELADA_CANCELLED
  PELADA_FINISHED
  ATTENDANCE_CONFIRMED
}

enum PlaceRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TournamentStatus {
  DRAFT               // Criado, não publicado
  OPEN                // Publicado, inscrições abertas
  REGISTRATION_CLOSED // Inscrições encerradas, campeonato não iniciado
  IN_PROGRESS         // Em andamento
  FINISHED            // Finalizado
  CANCELLED           // Cancelado
}

enum TournamentFormat {
  LEAGUE                // Pontos corridos
  KNOCKOUT              // Mata-mata
  GROUPS_AND_KNOCKOUT   // Grupos + eliminatória
  DOUBLE_ELIMINATION    // Eliminatória dupla
  SWISS                 // Sistema suíço
}

enum TournamentParticipantType {
  TEAM
  INDIVIDUAL
}

enum TournamentRegistrationMode {
  OPEN
  APPROVAL_REQUIRED
}

enum OrganizerType {
  PLACE
  USER
  COMPANY
  OTHER
}

enum CompetitionLevel {
  BEGINNER
  INTERMEDIATE
  AMATEUR
  ADVANCED
  PROFESSIONAL
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id                 String     @id @default(cuid())
  name               String
  email              String     @unique
  password           String?    // null quando o login é pelo Google
  avatarUrl          String?
  pixKey             String?
  role               UserRole   @default(PLAYER)
  badge              UserBadge?
  resetToken         String?    @unique
  resetTokenExpiry   DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  accounts              Account[]
  placesOwned           Place[]
  placeRequests         PlaceRequest[]
  peladasCreated        Pelada[]        @relation("OrganizerPeladas")
  participations        Participation[]
  reviewsGiven          Review[]        @relation("ReviewsGiven")
  reviewsReceived       Review[]        @relation("ReviewsReceived")
  tournamentsCreated    Tournament[]    @relation("TournamentsCreated")
  tournamentsOrganized  Tournament[]    @relation("TournamentsOrganized")
  notifications         Notification[]
}

// Armazena contas OAuth (Google) e permite login híbrido
model Account {
  id                String   @id @default(cuid())
  userId            String
  provider          String   // "google"
  providerAccountId String   // sub do token Google
  accessToken       String?
  refreshToken      String?
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// Estabelecimento físico cadastrado pelo admin e gerenciado pelo OWNER
model Place {
  id           String      @id @default(cuid())
  name         String

  // Endereço estruturado para geocoding
  street       String      // Nome da rua/avenida
  number       String      // Número
  complement   String?     // Bloco, sala, etc.
  neighborhood String      // Bairro
  city         String      // Cidade
  state        String      // UF (ex: "SP")
  zipCode      String      // CEP
  country      String      @default("BR")

  // Coordenadas preenchidas via Google Geocoding API
  latitude     Float?
  longitude    Float?

  status       PlaceStatus @default(OPEN)
  ownerId      String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  owner       User?        @relation(fields: [ownerId], references: [id])
  courts      Court[]
  tournaments Tournament[]
}

// Espaço de jogo dentro de um estabelecimento, gerenciado pelo OWNER
model Court {
  id           String      @id @default(cuid())
  placeId      String
  name         String      // "Quadra 1", "Campo Principal", etc.
  type         CourtType
  pricePerHour Decimal?    @db.Decimal(10, 2)
  status       CourtStatus @default(OPEN)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  place   Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  peladas Pelada[]
}

model Pelada {
  id          String       @id @default(cuid())
  courtId     String
  organizerId String
  date        DateTime
  maxPlayers  Int
  totalValue  Decimal      @db.Decimal(10, 2)
  pixKey      String
  status      PeladaStatus @default(WAITING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  court          Court           @relation(fields: [courtId], references: [id])
  organizer      User            @relation("OrganizerPeladas", fields: [organizerId], references: [id])
  participations Participation[]
  reviews        Review[]
}

model Participation {
  id       String   @id @default(cuid())
  peladaId String
  userId   String
  attended Boolean? // null = pelada ainda não finalizada; true/false = presença confirmada
  joinedAt DateTime @default(now())

  pelada Pelada @relation(fields: [peladaId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([peladaId, userId])
}

// Solicitação de cadastro de um novo Place feita por um OWNER — aprovada ou rejeitada pelo Admin
model PlaceRequest {
  id           String             @id @default(cuid())
  ownerId      String
  name         String
  street       String
  number       String
  complement   String?
  neighborhood String
  city         String
  state        String
  zipCode      String
  country      String             @default("BR")
  latitude     Float?
  longitude    Float?
  status       PlaceRequestStatus @default(PENDING)
  adminNote    String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}

model Review {
  id         String    @id @default(cuid())
  peladaId   String
  reviewerId String
  reviewedId String
  stars      Int       // 1 a 5
  tag        ReviewTag
  comment    String?
  createdAt  DateTime  @default(now())

  pelada   Pelada @relation(fields: [peladaId], references: [id], onDelete: Cascade)
  reviewer User   @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  reviewed User   @relation("ReviewsReceived", fields: [reviewedId], references: [id])

  @@unique([peladaId, reviewerId, reviewedId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  data      Json?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Campeonato realizado em um Place
model Tournament {
  id                    String                     @id @default(cuid())
  name                  String
  description           String?
  placeId               String
  createdById           String
  organizerType         OrganizerType              @default(PLACE)
  organizerName         String?
  organizerUserId       String?
  sportType             CourtType
  format                TournamentFormat
  participantType       TournamentParticipantType  @default(TEAM)
  status                TournamentStatus           @default(DRAFT)
  registrationMode      TournamentRegistrationMode @default(OPEN)
  registrationStartDate DateTime?
  registrationEndDate   DateTime?
  startDate             DateTime?
  endDate               DateTime?
  maxParticipants       Int?
  registrationFee       Decimal?                   @db.Decimal(10, 2)
  paymentInstructions   String?
  pixKey                String?
  rules                 String?
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt

  place         Place                @relation(fields: [placeId], references: [id])
  createdBy     User                 @relation("TournamentsCreated", fields: [createdById], references: [id])
  organizerUser User?                @relation("TournamentsOrganized", fields: [organizerUserId], references: [id])
  divisions     TournamentDivision[]
}

// Categoria/divisão dentro de um campeonato (ex: Masculino Iniciante, Misto Intermediário)
model TournamentDivision {
  id                String           @id @default(cuid())
  tournamentId      String
  name              String
  description       String?
  genderRestriction String?
  ageRestriction    String?
  level             CompetitionLevel @default(AMATEUR)
  minPlayersPerTeam Int              @default(2)
  maxPlayersPerTeam Int              @default(2)
  maxParticipants   Int?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
}
