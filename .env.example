PORT=3000
NODE_ENV=development

# Neon PostgreSQL
# DATABASE_URL  → URL com pooling (usada pela aplicação)
# DIRECT_URL    → URL direta sem pooling (usada pelo Prisma Migrate)
# Ambas estão disponíveis no painel do seu projeto em neon.tech
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/futmatch?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/futmatch?sslmode=require"

JWT_SECRET="your_jwt_secret"
JWT_EXPIRES_IN="1d"

# Google OAuth
# Obtenha em: console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
